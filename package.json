{
  "name": "shop-logbook",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && cross-env GITHUB_PAGES=true vite build && node scripts/copy-404.mjs",
    "lint": "oxlint",
    "preview": "vite preview",
    "deploy:cloudflare": "npm run build && npx wrangler pages deploy dist --project-name=logbookcayden"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "cross-env": "^7.0.3",
    "netlify-cli": "^26.1.0",
    "oxlint": "^1.69.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "wrangler": "^4.104.0"
  }
}
